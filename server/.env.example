# ============================================================
# Environment Variables — Ermel Server
# Copy this file to .env and fill in values
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ermel

# Session secret (use a long random string in production)
SESSION_SECRET=your-secure-random-session-secret-here

# Gmail SMTP credentials
# Use an App Password (not your Gmail password)
# See: https://myaccount.google.com/apppasswords
# Tip: App passwords are shown with spaces; remove spaces or wrap in quotes.
GMAIL_USER=ermelglassaluminum@gmail.com
# Preferred (supports Gmail app password copy format)
GMAIL_APP_PASSWORD=your-gmail-app-password
# Backward-compatible fallback
GMAIL_PASS=your-gmail-app-password

# Resend API (recommended on Render)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Ermel Glass & Aluminum <no-reply@yourdomain.com>

# Base URL for verification email links
BASE_URL=http://localhost:5173

# Frontend URL for email links and CORS allowlist fallback
FRONTEND_URL=http://localhost:5173

# Comma-separated CORS origins allowed to call the API in production
CORS_ORIGIN=http://localhost:5173

# Server port (optional, defaults to 4000)
PORT=4000

# Node environment
NODE_ENV=development

# Session cookie SameSite policy.
# Use none for cross-origin frontend/backend (e.g., separate Render services).
SESSION_SAME_SITE=lax
