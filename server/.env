# ============================================================
# Ermel Server — Environment Configuration
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ermel

# Session secret
SESSION_SECRET=ermel-dev-secret-change-in-production

# Gmail SMTP credentials (fill in to enable email verification)
GMAIL_USER=
GMAIL_PASS=

# Base URL for verification email links
BASE_URL=http://localhost:5173

# Server port
PORT=4000

# Node environment
NODE_ENV=development
